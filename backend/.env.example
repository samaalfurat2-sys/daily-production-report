# ─────────────────────────────────────────────────────────────
# Daily Production Report — Environment Configuration
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# SQLite (local dev / single-machine):
DATABASE_URL=sqlite:///./production_app.db

# PostgreSQL (multi-user production):
# DATABASE_URL=postgresql+psycopg2://prod_user:STRONG_PASSWORD@localhost:5432/prod_report

# ── Security ─────────────────────────────────────────────────
# REQUIRED: Replace with a cryptographically random secret.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# Token lifetime in minutes (default 12 hours)
JWT_EXPIRE_MINUTES=720

# ── Shifts ───────────────────────────────────────────────────
# Comma-separated shift codes in chronological order
SHIFT_ORDER=A,B,C

# ── CORS ─────────────────────────────────────────────────────
# Development only — allows all origins:
# CORS_ORIGINS=*
#
# Production — restrict to exact frontend origin(s):
CORS_ORIGINS=http://localhost:PORT,https://your-app-domain.com
