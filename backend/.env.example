# ─────────────────────────────────────────────────────────────────────────────
# Daily Production Report v2.2 — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev / Railway with persistent volume):
DATABASE_URL=sqlite:///./production_app.db

# PostgreSQL (multi-user production):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRE_MINUTES=720

# ── Shifts ───────────────────────────────────────────────────────────────────
SHIFT_ORDER=A,B,C

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allow all (dev):
CORS_ORIGINS=*
# Production (add your Railway domain):
# CORS_ORIGINS=https://your-app.up.railway.app,http://localhost:8000

# ── Microsoft OneDrive / Graph API ──────────────────────────────────────────
# Step 1: Register a free Azure app at https://portal.azure.com
#         OR use the built-in public client ID (no registration needed):
ONEDRIVE_CLIENT_ID=d3590ed6-52b3-4102-aeff-aad2292ab01c

# Step 2: After running GET /onedrive/setup in the API and completing sign-in,
#         paste the refresh_token returned by POST /onedrive/setup/complete here:
ONEDRIVE_REFRESH_TOKEN=

# Step 3: OneDrive folder where files will be stored (created automatically):
ONEDRIVE_FOLDER=ProductionReports
