# ════════════════════════════════════════════════════
#  Daily Production Report v2.2 — Environment Config
# ════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./production_app.db

# PostgreSQL (Railway provides this automatically as $DATABASE_URL):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Security ─────────────────────────────────────────
JWT_SECRET=replace_with_64_char_hex_string_here
JWT_EXPIRE_MINUTES=720

# ── App Settings ─────────────────────────────────────
SHIFT_ORDER=A,B,C
CORS_ORIGINS=*
SEED_DEMO=true

# ── Microsoft OneDrive (optional) ────────────────────
# Get client ID from: https://portal.azure.com → App Registrations
ONEDRIVE_CLIENT_ID=d3590ed6-52b3-4102-aeff-aad2292ab01c
# Set this after completing device-code auth flow in the app:
ONEDRIVE_REFRESH_TOKEN=
ONEDRIVE_FOLDER=ProductionReports
